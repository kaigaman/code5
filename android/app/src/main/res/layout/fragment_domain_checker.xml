<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/title_domain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/domain_checker_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_domain_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:endIconMode="clear_text"
        app:layout_constraintTop_toBottomOf="@id/title_domain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_search">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_domain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/domain_hint"
            android:inputType="textUri"
            android:imeOptions="actionSearch" />

    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btn_search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_search"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/input_domain_layout"
        app:layout_constraintBottom_toBottomOf="@id/input_domain_layout"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:visibility="gone"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/input_domain_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/domain_results"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/loading_spinner"
        app:layout_constraintBottom_toTopOf="@id/btn_check_another"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <Button
        android:id="@+id/btn_check_another"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_check_another"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/domain_results"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/title_whois"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/whois_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_check_another"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_whois_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:endIconMode="clear_text"
        app:layout_constraintTop_toBottomOf="@id/title_whois"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_whois"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_whois"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/whois_hint"
            android:inputType="textUri"
            android:imeOptions="actionSearch" />

    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btn_whois"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_whois"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/input_whois_layout"
        app:layout_constraintBottom_toBottomOf="@id/input_whois_layout"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
